From 66d03e3b848680d5231b68a0ed8c9ac3a587a3f3 Mon Sep 17 00:00:00 2001
From: janet-darwin8-ppc <janet-darwin8-ppc@local>
Date: Fri, 15 May 2026 22:41:47 -0500
Subject: [PATCH 2/4] os.c: gate <spawn.h> include behind JANET_NO_PROCESSES

The JANET_NO_PROCESSES flag already wraps the os/spawn, os/execute,
os/shell, os/posix-fork, and os/posix-exec machinery and their core
registrations (os.c lines 343-1640 and 3004+).  But the top-level
#include <spawn.h> at line 62 was outside any guard, so on systems
that lack <spawn.h> (e.g. macOS 10.4 Tiger), building with
-DJANET_NO_PROCESSES still failed.

This one-line change lets pre-Leopard Apple builds compile by
passing -DJANET_NO_PROCESSES via CPPFLAGS.  On Plan 9 the include
is also skipped (existing behavior preserved).
---
 src/core/os.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/core/os.c b/src/core/os.c
index bc7b7bd6..7f489e19 100644
--- a/src/core/os.c
+++ b/src/core/os.c
@@ -58,7 +58,7 @@
 #include <process.h>
 #define JANET_SPAWN_CHDIR
 #else
-#ifndef JANET_PLAN9
+#if !defined(JANET_PLAN9) && !defined(JANET_NO_PROCESSES)
 #include <spawn.h>
 #endif
 #include <utime.h>
